@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<style>
    .auth-header {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 2rem;
        border-radius: 1rem 1rem 0 0;
        text-align: center;
    }
    .auth-card {
        border-radius: 1rem;
        border: none;
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15);
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">
            <div class="card auth-card">
                <div class="auth-header">
                    <h2 class="fw-bold mb-1">Welcome Back</h2>
                    <p class="mb-0 opacity-75">Log in to your account</p>
                </div>
                
                <div class="card-body p-4 p-sm-5">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control rounded-pill px-4" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="px-4">Email Address</label>
                            <span asp-validation-for="Input.Email" class="text-danger ps-4 small"></span>
                        </div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Input.Password" class="form-control rounded-pill px-4" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="px-4">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger ps-4 small"></span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label text-muted" asp-for="Input.RememberMe">
                                    Remember me
                                </label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none small fw-bold text-primary">Forgot password?</a>
                        </div>
                        
                        <button id="login-submit" type="submit" class="btn btn-primary w-100 btn-lg rounded-pill shadow-sm fw-bold mb-4">Log in</button>
                        
                        <div class="text-center text-muted small">
                            Don't have an account? 
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold text-primary">Sign up here</a>
                            <br/>
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-decoration-none mt-2 d-inline-block opacity-75 hover-primary">Resend email confirmation</a>
                        </div>
                    </form>
                </div>
            </div>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="text-center mt-4">
                    <p class="text-muted small fw-bold text-uppercase mb-3">Or continue with</p>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                        <div class="d-flex justify-content-center gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                    @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
