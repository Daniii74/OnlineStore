@model OnlineStore.Models.Category

@{
    ViewData["Title"] = "Create Category";
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 2rem;
        border-radius: 1rem 1rem 0 0;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="admin-header">
                    <h2 class="fw-bold mb-0">Create Category</h2>
                    <p class="mb-0 opacity-75">Add a new category to your store</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Name" class="form-control rounded-pill px-4" placeholder="Category Name" />
                            <label asp-for="Name" class="px-4 text-muted">Category Name</label>
                            <span asp-validation-for="Name" class="text-danger ps-4 small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label text-muted fw-bold ps-3 mb-1">Description</label>
                            <textarea asp-for="Description" class="form-control rounded-4 p-3" rows="4" placeholder="Enter category description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger ps-3 small"></span>
                        </div>

                        <div class="mb-4">
                            <label for="image" class="form-label text-muted fw-bold ps-3 mb-1">Category Image</label>
                            <input type="file" name="image" class="form-control rounded-pill px-4" />
                            <div class="form-text ps-3">Upload an image covering this category.</div>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm fw-bold">Create Category</button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-bold">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
