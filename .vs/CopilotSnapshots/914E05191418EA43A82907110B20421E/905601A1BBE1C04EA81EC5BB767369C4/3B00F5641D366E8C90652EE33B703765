@model IEnumerable<OnlineStore.Models.Product>

@{
    ViewData["Title"] = "Home Page";
}

<div class="jumbotron w-100">
    <h1 class="display-4 text-center w-100" >Welcome to the Online Store</h1>
</div>

<div class="container py-2">
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-50">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Description</p>
                        <p class="card-text fw-bold">$@product.Price</p>
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId" class="btn btn-primary mt-auto">View Details</a>
                        @if(User.Identity.Name != "admin@email.com")
                        {
                        <form asp-controller="CartItems" asp-action="AddtoCart" asp-route-id="@product.ProductId">
                            <button type="submit" class="btn btn-primary mt-1 w-100">Add to Cart</button> 
                        </form> 
                        }
                    </div>
                </div>
            </div>
        }
    </div> 
</div>
