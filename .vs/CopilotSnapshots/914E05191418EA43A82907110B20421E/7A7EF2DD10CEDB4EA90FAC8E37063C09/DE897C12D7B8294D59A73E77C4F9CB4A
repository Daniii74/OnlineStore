@model IEnumerable<OnlineStore.Models.Product>

@{
    ViewData["Title"] = "Home Page";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
    }
    .product-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .price-tag {
        font-size: 1.1rem;
        font-weight: 700;
        color: #198754;
    }
    .card-img-wrapper {
        height: 250px;
        overflow: hidden;
    }
    .card-img-wrapper img {
        height: 100%;
        width: 100%;
        object-fit: contain;
        background-color: #f8f9fa; /* Optional: distinct background for empty spaces */
        padding: 0.5rem;
    }
</style>

<div class="p-5 mb-5 text-center text-white rounded-4 shadow hero-section">
    <h1 class="display-3 fw-bold mb-3">Welcome to the Online Store</h1>
    <p class="lead mb-4 fs-4 opacity-75">Discover incredible products at unbeatable prices.</p>
    <a href="#products" class="btn btn-light btn-lg px-5 rounded-pill fw-bold text-primary shadow-sm" style="scroll-behavior: smooth;">Start Shopping</a>
</div>

<div class="container pb-5" id="products">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 product-card">
                    <div class="card-img-wrapper rounded-top-4">
                        <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" />
                    </div>
                    
                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">@product.Name</h5>
                            <span class="price-tag">$@product.Price</span>
                        </div>
                        
                        <p class="card-text text-muted mb-4 flex-grow-1">
                            @(string.IsNullOrEmpty(product.Description) ? "No description available." : product.Description)
                        </p>
                        
                        <div class="mt-auto d-flex flex-column gap-2">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId" class="btn btn-outline-dark rounded-pill shadow-sm">View Details</a>
                            
                            @if(User?.Identity?.Name != "admin@email.com")
                            {
                                <form asp-controller="CartItems" asp-action="AddtoCart" asp-route-id="@product.ProductId" class="w-100">
                                    <button type="submit" class="btn btn-primary w-100 rounded-pill shadow-sm fw-bold">
                                        Add to Cart
                                    </button> 
                                </form> 
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div> 
</div>
