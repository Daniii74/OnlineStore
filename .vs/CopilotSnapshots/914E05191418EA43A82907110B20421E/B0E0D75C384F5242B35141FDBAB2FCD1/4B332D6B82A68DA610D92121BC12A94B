@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    .auth-header {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 2rem;
        border-radius: 1rem 1rem 0 0;
        text-align: center;
    }
    .auth-card {
        border-radius: 1rem;
        border: none;
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15);
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">
            <div class="card auth-card">
                <div class="auth-header">
                    <h2 class="fw-bold mb-1">Create Account</h2>
                    <p class="mb-0 opacity-75">Join us and start shopping</p>
                </div>
                
                <div class="card-body p-4 p-sm-5">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control rounded-pill px-4" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="px-4">Email Address</label>
                            <span asp-validation-for="Input.Email" class="text-danger ps-4 small"></span>
                        </div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Input.Password" class="form-control rounded-pill px-4" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="px-4">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger ps-4 small"></span>
                        </div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Input.ConfirmPassword" class="form-control rounded-pill px-4" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.ConfirmPassword" class="px-4">Confirm Password</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger ps-4 small"></span>
                        </div>
                        
                        <button id="registerSubmit" type="submit" class="btn btn-primary w-100 btn-lg rounded-pill shadow-sm fw-bold mb-4">Sign Up</button>
                        
                        <div class="text-center text-muted small">
                            Already have an account? 
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold text-primary">Log in instead</a>
                        </div>
                    </form>
                </div>
            </div>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="text-center mt-4">
                    <p class="text-muted small fw-bold text-uppercase mb-3">Or register with</p>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                        <div class="d-flex justify-content-center gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                    @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
