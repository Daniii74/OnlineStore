@model OnlineStore.Models.Product

@{
    ViewData["Title"] = "Details";
}
<div class="container py-4">
    <div class="row align-items-start">

       
        <div class="col-md-5">
            <img src="@Model.ImageUrl"
                 alt="@Model.Name"
                 class="img-fluid rounded shadow-sm" />
        </div>

        
        <div class="col-md-7">
            <h1>@Model.Name</h1>

            <p>@Model.Description</p>

            <p>
                <strong>Category:</strong> @Model.Category.Name
            </p>

            <h3 class="text-primary">$@Model.Price</h3>
            @if(User.Identity.Name != "admin@email.com")
            {
            <a asp-controller="CartItems"
               asp-action="Add"
               asp-route-id="@Model.ProductId"
               class="btn btn-primary">
                Add to Cart
            </a>
            }
            else
            {
                <p>
                    <strong>Stock:</strong> @Model.Stock
                </p>
                <p>
                    <strong>Created Date:</strong> @Model.CreatedDate
                </p>
                <p>
                    <strong>Category:</strong> @Model.Category.Name
                </p>
                <p>
                    <strong>IsActive:</strong> @Model.IsActive
                </p>
                <a asp-action="Edit"
                   asp-route-id="@Model.ProductId"
                   class="btn btn-outline-primary">
                    Edit Product
                </a>
            }
        </div>

    </div>
</div>
