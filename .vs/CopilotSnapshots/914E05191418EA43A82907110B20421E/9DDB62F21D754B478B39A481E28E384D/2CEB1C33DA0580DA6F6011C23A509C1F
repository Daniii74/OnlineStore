@model OnlineStore.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<style>
    .details-card {
        border-radius: 1rem;
        border: none;
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15);
        overflow: hidden;
    }
    .product-img-detail {
        width: 100%;
        max-height: 500px;
        object-fit: contain;
        background-color: #f8f9fa;
        padding: 2rem;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card details-card">
                <div class="row g-0">
                    <div class="col-md-5 border-end">
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="product-img-detail" />
                    </div>
                    <div class="col-md-7">
                        <div class="card-body p-5 h-100 d-flex flex-column">
                            <div class="mb-2">
                                <span class="badge bg-secondary mb-2">@Model.Category.Name</span>
                                <h1 class="card-title fw-bold">@Model.Name</h1>
                            </div>
                            
                            <h2 class="text-success fw-bold mb-4">$@Model.Price</h2>
                            
                            <p class="card-text text-muted mb-5 flex-grow-1" style="font-size: 1.1rem; line-height: 1.6;">
                                @(string.IsNullOrEmpty(Model.Description) ? "No description available." : Model.Description)
                            </p>

                            @if(User?.Identity?.Name != "admin@email.com")
                            {
                                <div class="mt-auto">
                                    <form asp-controller="CartItems" asp-action="AddtoCart" asp-route-id="@Model.ProductId">
                                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm fw-bold">
                                            Add to Cart
                                        </button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <div class="mt-auto bg-light p-4 rounded-4">
                                    <h5 class="fw-bold mb-3">Admin Details</h5>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted">Stock:</span>
                                        <span class="fw-bold">@Model.Stock</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted">Created Date:</span>
                                        <span class="fw-bold">@Model.CreatedDate.ToShortDateString()</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-3">
                                        <span class="text-muted">Status:</span>
                                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                                            @(Model.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                    <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-outline-primary w-100 rounded-pill shadow-sm fw-bold">
                                        Edit Product
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-4 text-center">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm px-4">Back to List</a>
            </div>
        </div>
    </div>
</div>
