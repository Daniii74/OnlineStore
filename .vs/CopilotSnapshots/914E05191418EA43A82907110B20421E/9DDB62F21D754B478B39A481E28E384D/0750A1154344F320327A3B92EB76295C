@model OnlineStore.Models.Category

@{
    ViewData["Title"] = "Category Details";
}

<style>
    .details-card {
        border-radius: 1rem;
        border: none;
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15);
        overflow: hidden;
    }
    .category-img-detail {
        width: 100%;
        max-height: 400px;
        object-fit: cover;
    }
    .header-banner {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 2rem;
        border-radius: 1rem 1rem 0 0;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card details-card">
                <div class="header-banner text-center">
                    <h1 class="fw-bold mb-0">@Model.Name</h1>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="category-img-detail" />
                }
                else
                {
                    <div class="bg-light text-center py-5">
                        <span class="text-muted fs-4">No Image Available</span>
                    </div>
                }

                <div class="card-body p-5">
                    <h4 class="fw-bold border-bottom pb-3 mb-4">Category Details</h4>
                    
                    <div class="mb-4">
                        <h6 class="text-muted fw-bold mb-2">Description</h6>
                        <p class="fs-5 mb-0" style="line-height: 1.6;">
                            @(string.IsNullOrEmpty(Model.Description) ? "No description available." : Model.Description)
                        </p>
                    </div>

                    <div class="d-flex gap-3 mt-5">
                        <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="btn btn-primary rounded-pill shadow-sm px-4 fw-bold">Edit Category</a>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm px-4 fw-bold">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
