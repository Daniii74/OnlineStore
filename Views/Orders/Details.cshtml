@model IEnumerable<OnlineStore.Models.OrderDetail>
@{
    ViewData["Title"] = "Order Details";
}

<style>
    .order-header {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 2rem;
        border-radius: 1rem 1rem 0 0;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="order-header d-flex justify-content-between align-items-center">
                    <h2 class="fw-bold mb-0">Order Details</h2>
                    <span class="badge bg-light text-primary fs-6 px-3 py-2 rounded-pill shadow-sm">
                        Total Items: @(Model?.Count() ?? 0)
                    </span>
                </div>
                
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" class="ps-4 py-3">Order ID</th>
                                    <th scope="col" class="py-3">Product Name</th>
                                    <th scope="col" class="text-center py-3">Quantity</th>
                                    <th scope="col" class="text-end py-3">Unit Price</th>
                                    <th scope="col" class="pe-4 text-end py-3">Total Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-muted">
                                                #@item.OrderId
                                            </td>
                                            <td class="fw-bold text-dark">
                                                @item.Product.Name
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-secondary rounded-pill px-3 py-2">@item.Quantity</span>
                                            </td>
                                            <td class="text-end text-muted">
                                                $@item.Product.Price
                                            </td>
                                            <td class="pe-4 text-end fw-bold text-success">
                                                $@item.Price
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">No items found for this order.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                
                @if (Model != null && Model.Any())
                {
                    <div class="card-footer bg-light p-4 d-flex justify-content-end align-items-center border-0">
                        <span class="text-muted fs-5 me-3">Order Total:</span>
                        <span class="fs-4 fw-bold text-success">$@Model.Sum(x => x.Price)</span>
                    </div>
                }
            </div>
            
            <div class="mt-4 text-center">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm px-5 fw-bold">Back to Orders</a>
            </div>
        </div>
    </div>
</div>
