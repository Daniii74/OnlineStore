@model OnlineStore.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<style>
    .danger-header {
        background: linear-gradient(135deg, #dc3545 0%, #a71d2a 100%);
        color: white;
        padding: 2rem;
        border-radius: 1rem 1rem 0 0;
        text-align: center;
    }
    .preview-img {
        width: 100%;
        max-height: 250px;
        object-fit: cover;
        border-radius: 0.5rem;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="danger-header">
                    <h2 class="fw-bold mb-1">Delete Category</h2>
                    <p class="mb-0 fs-5">Are you sure you want to delete this category?</p>
                </div>
                
                <div class="card-body p-4 p-md-5 bg-light">
                    <div class="bg-white rounded-4 shadow-sm p-4 text-center mb-4">
                        <h3 class="fw-bold text-dark mb-3">@Html.DisplayFor(model => model.Name)</h3>
                        
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="preview-img shadow-sm mb-4" />
                        }

                        <p class="text-muted mb-0">
                            @(string.IsNullOrEmpty(Model.Description) ? "No description available." : Model.Description)
                        </p>
                    </div>

                    <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0 me-3" viewBox="0 0 16 16">
                          <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                        </svg>
                        <div>
                            <strong>Warning:</strong> This action cannot be undone. Any products tied to this category may be affected.
                        </div>
                    </div>

                    <form asp-action="Delete" class="d-flex justify-content-center gap-3">
                        <input type="hidden" asp-for="CategoryId" />
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-5 py-2 shadow-sm fw-bold">Cancel</a>
                        <button type="submit" class="btn btn-danger rounded-pill px-5 py-2 shadow-sm fw-bold">Yes, Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
