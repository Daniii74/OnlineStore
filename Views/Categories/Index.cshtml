@model IEnumerable<OnlineStore.Models.Category>

@{
    ViewData["Title"] = "Categories Management";
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 2rem;
        border-radius: 1rem 1rem 0 0;
    }
    .thumb-img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 0.5rem;
    }
</style>

<div class="container py-4">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="admin-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-0">Categories Management</h2>
                <p class="mb-0 opacity-75">Manage your store categories</p>
            </div>
            <a asp-action="Create" class="btn btn-light text-primary rounded-pill px-4 py-2 fw-bold shadow-sm">
                + Create New
            </a>
        </div>
        
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="ps-4 py-3">Image</th>
                            <th scope="col" class="py-3">Name</th>
                            <th scope="col" class="py-3">Description</th>
                            <th scope="col" class="py-3 text-center">Created Date</th>
                            <th scope="col" class="pe-4 py-3 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model) {
                                <tr>
                                    <td class="ps-4 py-3">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@Url.Content(item.ImageUrl)" alt="@item.Name" class="thumb-img shadow-sm" />
                                        }
                                        else
                                        {
                                            <div class="bg-light d-flex align-items-center justify-content-center thumb-img border text-muted small">
                                                N/A
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-bold text-dark">
                                        @item.Name
                                    </td>
                                    <td class="text-muted text-truncate" style="max-width: 250px;" title="@item.Description">
                                        @item.Description
                                    </td>
                                    <td class="text-muted text-center">
                                        @item.CreatedDate.ToShortDateString()
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm">Edit</a>
                                            <a asp-action="Details" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-info rounded-pill px-3 shadow-sm">Details</a>
                                            <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <div class="py-4">
                                        <h5 class="fw-bold mb-3">No categories found</h5>
                                        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">Create the first category</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
