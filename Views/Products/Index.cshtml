@model IEnumerable<OnlineStore.Models.Product>

@{
    ViewData["Title"] = "Products Management";
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 2rem;
        border-radius: 1rem 1rem 0 0;
    }
    .thumb-img {
        width: 60px;
        height: 60px;
        object-fit: contain;
        background-color: #f8f9fa;
        padding: 0.25rem;
        border-radius: 0.5rem;
    }
</style>

<div class="container-fluid py-4" style="max-width: 1400px;">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="admin-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h2 class="fw-bold mb-0">Products Management</h2>
                <p class="mb-0 opacity-75">Manage your store inventory</p>
            </div>
            <a asp-action="Create" class="btn btn-light text-primary rounded-pill px-4 py-2 fw-bold shadow-sm">
                + Create New Model
            </a>
        </div>
        
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-nowrap">
                        <tr>
                            <th scope="col" class="ps-4 py-3">Image</th>
                            <th scope="col" class="py-3">Name</th>
                            <th scope="col" class="py-3">Category</th>
                            <th scope="col" class="py-3 text-end">Price</th>
                            <th scope="col" class="py-3 text-center">Stock</th>
                            <th scope="col" class="py-3 text-center">Status</th>
                            <th scope="col" class="py-3 text-center">Added</th>
                            <th scope="col" class="pe-4 py-3 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model) {
                                <tr>
                                    <td class="ps-4 py-3">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Name" class="thumb-img shadow-sm border" />
                                        }
                                        else
                                        {
                                            <div class="bg-light d-flex align-items-center justify-content-center thumb-img border text-muted small">
                                                N/A
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-bold text-dark">
                                        @item.Name
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary rounded-pill px-2 py-1">@item.Category.Name</span>
                                    </td>
                                    <td class="text-end fw-bold text-success">
                                        $@item.Price
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(item.Stock > 0 ? "bg-light text-dark border" : "bg-danger") rounded-pill px-3 py-2">
                                            @item.Stock
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-2">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-2">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-muted text-center small">
                                        @item.CreatedDate.ToShortDateString()
                                    </td>
                                    <td class="pe-4 text-end text-nowrap">
                                        <div class="d-flex justify-content-end gap-1">
                                            <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm">Edit</a>
                                            <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-info rounded-pill px-3 shadow-sm">Details</a>
                                            <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <div class="py-4">
                                        <h5 class="fw-bold mb-3">No products found</h5>
                                        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">Create the first product</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

